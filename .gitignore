# Python cache files
__pycache__/
*.pyc
*.pyo
*.pyd

# Jupyter Notebook checkpoints
.ipynb_checkpoints/
*/.ipynb_checkpoints/

# Virtual environments
venv/
.venv/
env/

# Large raw datasets (must be ignored to avoid exceeding GitHub size limits)
data/raw/
data/raw/*

# Keep processed data and models so the deployed app can access them
!data/processed/cleaned_matches.csv
!data/processed/cleaned_deliveries.csv
!models/match_predictor.pkl
!models/player_predictor.pkl

# Local Streamlit config (optional to ignore, but we keep config.toml for dark theme)
.streamlit/secrets.toml
